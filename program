function drawenemycontrol(){
  let diff={x:0,y:0};
  let dist;
  let over;
  let nx;
  let ny;
  for(let e=0;e<enemy.length;e++){
    for(let i=e+1;i<enemy.length;i++){
      if(e===i){
        continue;
      }
      diff.x=enemy[e].x-enemy[i].x
      diff.y=enemy[e].y-enemy[i].y
      dist=Math.sqrt(diff.x*diff.x+diff.y*diff.y)
      if(dist===0){
        continue;
      }
      over=enemy[e].radius+enemy[i].radius-dist;
      nx=diff.x/dist
      ny=diff.y/dist
      if(over>0){
        enemy[e].x-=nx*over;
        enemy[e].y-=ny*over;
        enemy[i].x+=nx*over;
        enemy[i].y+=ny*over;
      }
    }
  }
}
