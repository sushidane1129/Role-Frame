function drawenemycontrol(){
  let diff={x:0,y:0};
  let distance;
  let over;
  let aim={x:0,y:0};
  for(let e=0;e<enemy.length;e++){
    for(let i=e+1;i<enemy.length;i++){
      if(e===i){
        continue;
      }
      diff.x=enemy[e].x-enemy[i].x
      diff.y=enemy[e].y-enemy[i].y
      distance=Math.sqrt(diff.x*diff.x+diff.y*diff.y)
      if(distance===0){
        continue;
      }
      over=enemy[e].radius+enemy[i].radius-distance;
      aim.x=diff.x/distance
      aim.y=diff.y/distance
      if(over>0){
        enemy[e].x-=aim.x*over;
        enemy[e].y-=aim.y*over;
        enemy[i].x+=aim.x*over;
        enemy[i].y+=aim.y*over;
      }
    }
  }
}
